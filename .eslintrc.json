{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "env": {
        "browser": true,
        "es2022": true,
        "node": true
    },
    "rules": {
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": [
            "error",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_"
            }
        ],
        "@typescript-eslint/no-explicit-any": "warn",
        "prefer-const": "error",
        "no-console": "warn"
    },
    "overrides": [
        {
            "files": [
                "test/**/*.ts",
                "src/**/*.test.ts"
            ],
            "rules": {
                "no-console": "off",
                "@typescript-eslint/no-explicit-any": "off"
            }
        },
        {
            "files": [
                "src/xhrInterceptor.ts",
                "src/xhrInterceptor.test.ts",
                "src/modules/dragdrop.ts"
            ],
            "rules": {
                "prefer-rest-params": "off",
                "@typescript-eslint/no-this-alias": "off",
                "@typescript-eslint/ban-ts-comment": "off",
                "no-empty": "off"
            }
        },
        {
            "files": [
                "*.js"
            ],
            "rules": {
                "@typescript-eslint/no-var-requires": "off"
            }
        }
    ]
}